{
  "functions": {
    "api/flights.js": { "maxDuration": 30 },
    "api/monitor-trips.js": { "maxDuration": 30 },
    "api/managed-trips.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/monitor-trips",
      "schedule": "0 */6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}